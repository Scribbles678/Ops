# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/scheduling

# SSL options (set to 'false' for local dev without SSL)
# Leave unset or set to 'true' for production with SSL
DATABASE_SSL=false

# JWT secret - must be at least 32 random characters
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace-this-with-a-long-random-secret-at-least-32-chars

# Node environment
NODE_ENV=production
